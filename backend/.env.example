# AI — NVIDIA NIM (cloud-based, free tier available)
# Get your key at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-...
NIM_MODEL=meta/llama-3.1-8b-instruct
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_TIMEOUT_MS=30000

# Backend
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# IP whitelist — non-browser clients (curl, scripts) are blocked in production unless their
# IP is listed here. Comma-separated. Example: 203.0.113.42,198.51.100.7
# Leave blank if no direct API access is needed outside the browser.
# In development, localhost (127.0.0.1 / ::1) is always allowed regardless of this setting.
ALLOWED_IPS=

# Rate limiting — AI routes (default: 15 requests per 15 min per IP)
# Tune these to control NVIDIA API spend. General API limit uses RATE_LIMIT_* above.
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX_REQUESTS=15

# Cache warming — protects POST /api/cache/warm. Set a random string in production.
CACHE_WARM_SECRET=

# Redis — local dev (ioredis). Leave blank to disable caching locally.
REDIS_URL=redis://localhost:6379

# Redis — production (Upstash). Setting this switches to @upstash/redis automatically.
# Get credentials at: https://upi wstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
