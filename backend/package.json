{
  "name": "wandrmark-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "ts-node --transpile-only src/db/init.ts",
    "warm-cache": "tsx src/scripts/warmCache.ts",
    "warm-cache:clear-cache": "npm run warm-cache -- --clear-cache",
    "warm-geocoding": "tsx src/scripts/warmGeocoding.ts"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "@upstash/redis": "^1.34.9",
    "ioredis": "^5.3.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
