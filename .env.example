# AI — NVIDIA NIM (cloud-based, free tier available)
# Get your key at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-key-here
NIM_MODEL=meta/llama-3.1-8b-instruct
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_TIMEOUT_MS=30000

# Backend
PORT=3001

# Redis (optional — app works without it, just no caching)
REDIS_URL=redis://localhost:6379

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org
NEXT_PUBLIC_OVERPASS_URL=https://overpass-api.de/api
NEXT_PUBLIC_OSRM_URL=http://router.project-osrm.org
